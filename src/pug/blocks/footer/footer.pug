include ../copyrights/copyrights

mixin footer(includeContacts)
  footer.footer(class=attributes.class)
    div.container.footer__content
      if includeContacts
        div.footer__background.parallax
          picture
            source(media="(max-width: 767px)" type="image/webp" data-srcset="img/footer-background-mobile@1x.webp 1x, img/footer-background-mobile@2x.webp 2x")
            source(media="(max-width: 767px)" data-srcset="img/footer-background-mobile@1x.jpg 1x, img/footer-background-mobile@2x.jpg 2x")
            source(media="(max-width: 1360px)" type="image/webp" data-srcset="img/footer-background-laptop@1x.webp 1x, img/footer-background-laptop@2x.webp 2x")
            source(media="(max-width: 1360px)" data-srcset="img/footer-background-laptop@1x.jpg 1x, img/footer-background-laptop@2x.jpg 2x")
            source(type="image/webp" data-srcset="img/footer-background@1x.webp 1x, img/footer-background@2x.webp 2x")
            img(data-src="img/footer-background@1x.jpg", data-srcset="img/footer-background@2x.jpg 2x", alt="").lazyload
        address.footer__contacts
          div.footer__element.footer__phone
            span.footer__element-title Телефон
            a(href="tel:+78123373241") 8 (812) 337-32-41
          div.footer__element.footer__email
            span.footer__element-title Электронная почта
            a(href="mailto:aaricoop@aari.ru") aaricoop@aari.ru
          div.footer__element.footer__address
            span.footer__element-title Адрес
            p Россия, 199397, г.&nbsp;Санкт-Петербург, ул. Беринга, дом 38
          a.button.button--light.footer__button Все контакты

      +copyrights().footer__copyrights


